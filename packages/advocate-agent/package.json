{
  "name": "@humanberto/advocate-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Portable, provider-agnostic AI advocate chat. Drop into any app: install, mount <AdvocateChat>, add one API route, supply a config.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./config": "./src/config.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .turbo node_modules"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.7.3"
  }
}
