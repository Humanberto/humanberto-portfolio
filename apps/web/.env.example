# --- AI advocate agent -------------------------------------------------------
# OPTION A (free, no credit card): Google AI Studio key. If set, Gemini is
# called directly. Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
ADVOCATE_GOOGLE_MODEL=gemini-2.5-flash

# OPTION B (fallback): Vercel AI Gateway (one key, many providers). Requires a
# card on file to use free credits. On Vercel deploys it's provided
# automatically. Used only when GOOGLE_GENERATIVE_AI_API_KEY is empty.
AI_GATEWAY_API_KEY=
# Gateway model id. Swap providers by changing only this line.
# Alternatives: openai/gpt-4o-mini, anthropic/claude-haiku-4.5
ADVOCATE_MODEL=google/gemini-2.0-flash

# --- Scheduling (Cal.com) ----------------------------------------------------
# From Cal.com: Event Types → your event → copy the public link slug after
# cal.com/ — e.g. if the URL is https://cal.com/you/30min set:
# NEXT_PUBLIC_CAL_LINK=you/30min
# Leave empty until your Cal.com event exists (site falls back to email).
NEXT_PUBLIC_CAL_LINK=

# --- Email (Resend) — used for "email me the transcript" --------------------
RESEND_API_KEY=
# Verified "from" address on your Resend domain.
ADVOCATE_FROM_EMAIL=advocate@humanberto.com
# Where lead notifications are sent.
ADVOCATE_NOTIFY_EMAIL=humanberto@gmail.com

# --- Lead capture (Supabase) -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://humanberto.com

# --- Hidden back office (/myoffice — not linked from public site) ------------
# Generate values: node apps/web/scripts/hash-admin-password.mjs "your-password"
ADMIN_PASSWORD_HASH=
# Dev only (never use in production): ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# 32-byte key, base64 — encrypts LLM API keys at rest in Supabase
ADMIN_ENCRYPTION_KEY=
