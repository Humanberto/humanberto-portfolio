# --- AI advocate agent -------------------------------------------------------
# Vercel AI Gateway key (one key, many providers). Get it at vercel.com.
# On Vercel deployments this is provided automatically and can be omitted.
AI_GATEWAY_API_KEY=

# Model id resolved by the gateway. Swap providers by changing only this line.
# Cheapest capable default: google/gemini-2.0-flash
# Alternatives: openai/gpt-4o-mini, anthropic/claude-haiku-4.5
ADVOCATE_MODEL=google/gemini-2.0-flash

# --- Scheduling (Cal.com) ----------------------------------------------------
# Your Cal.com "user/event" handle, e.g. humanberto/intro
NEXT_PUBLIC_CAL_LINK=

# --- Email (Resend) — used for "email me the transcript" --------------------
RESEND_API_KEY=
# Verified "from" address on your Resend domain.
ADVOCATE_FROM_EMAIL=advocate@humanberto.com
# Where lead notifications are sent.
ADVOCATE_NOTIFY_EMAIL=humanberto@gmail.com

# --- Lead capture (Supabase) -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://humanberto.com
